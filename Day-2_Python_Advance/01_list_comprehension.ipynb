   "source": [
    "***list comprension***\n",
    "- one line statement to generate a list from iterable objects"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "0710df70",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "[2, 4, 6, 8, 10, 12, 14, 16, 18]"
      ]
     },
     "execution_count": 4,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "new_number =[]\n",
    "for i in range(1, 20):\n",
    "    if i%2 == 0:\n",
    "        new_number.append(i)\n",
    "new_number"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
